# SFCE — Variables de entorno para infraestructura
# Copiar como .env y rellenar valores reales
# NUNCA commitear .env

# PostgreSQL 16 SFCE
SFCE_DB_PASSWORD=CAMBIAR_POR_CLAVE_ALEATORIA_FUERTE

# Restic — Hetzner Object Storage (S3 compatible)
RESTIC_REPOSITORY=s3:https://REGION.your-objectstorage.com/BUCKET_NAME
AWS_ACCESS_KEY_ID=TU_HETZNER_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=TU_HETZNER_SECRET_KEY
RESTIC_PASSWORD=CLAVE_CIFRADO_BACKUPS_MUY_FUERTE

# PostgreSQL connection para backups
BACKUP_PG_HOST=127.0.0.1
BACKUP_PG_PORT=5433
BACKUP_PG_USER=sfce_user
BACKUP_PG_DB=sfce_prod
