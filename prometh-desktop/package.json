{
  "name": "@prometh-ai/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PROMETH-AI Desktop — scrapers AAPP + certificados + sincronización con PROMETH-AI",
  "main": "./out/main/launcher.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && node scripts/post-build.mjs",
    "preview": "electron-vite preview",
    "build:win": "electron-vite build && electron-builder --win",
    "build:win:dir": "electron-vite build && electron-builder --win --dir",
    "clean": "rimraf out dist"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@signpdf/placeholder-pdf-lib": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "@signpdf/utils": "^3.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "fast-xml-parser": "^5.3.6",
    "lucide-react": "^0.469.0",
    "node-forge": "^1.3.3",
    "node-machine-id": "^1.1.12",
    "nodemailer": "^8.0.1",
    "p-limit": "^7.3.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "puppeteer-core": "^24.37.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^3.7.0",
    "tesseract.js": "^7.0.0",
    "xml-crypto": "^6.1.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/node-forge": "^1.3.14",
    "@types/nodemailer": "^7.0.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/xml-crypto": "^1.4.6",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "es.prometh-ai.desktop",
    "productName": "PROMETH-AI Desktop",
    "artifactName": "PromethAI-Desktop-Setup-${version}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PROMETH-AI Desktop",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "carlincarlichi78",
      "repo": "SPICE"
    }
  }
}
